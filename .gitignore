<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Minha Rotina Mágica 🐱✨🪼</title>
    <!-- Configurações para mobile/PWA -->
    <link rel="manifest" href="manifest.json">
    <meta name="theme-color" content="#a2d2ff">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <style>
        :root {
            --bg-color: #f0f4ff;
            --primary-color: #bde0fe;
            --secondary-color: #ffafcc;
            --accent-color: #8f61aa;
            --text-color: #4a4e69;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #a2d2ff, #9c64ad);
            color: var(--text-color);
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            margin: 0;
            overflow-x: hidden;
        }

        /* Elementos Decorativos */
        .decor {
            position: fixed;
            pointer-events: none;
            z-index: 0;
            font-size: 2rem;
            animation: float 6s ease-in-out infinite;
        }

        @keyframes float {
            0%, 100% { transform: translateY(0) rotate(0deg); }
            50% { transform: translateY(-20px) rotate(10deg); }
        }

        /* Container Principal */
        .container {
            background: rgba(255, 255, 255, 0.9);
            width: 90%;
            max-width: 500px;
            padding: 2rem;
            border-radius: 25px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            position: relative;
            z-index: 1;
            border: 4px solid white;
        }

        h1 {
            text-align: center;
            color: #7209b7;
            font-size: 1.8rem;
            margin-bottom: 1.5rem;
            text-shadow: 2px 2px #fff;
        }

        /* Formulário de Adição */
        .input-group {
            display: flex;
            flex-direction: column;
            gap: 10px;
            margin-bottom: 20px;
        }

        input {
            padding: 12px;
            border: 2px solid var(--primary-color);
            border-radius: 12px;
            outline: none;
            font-size: 1rem;
        }

        button#add-btn {
            background-color: var(--secondary-color);
            color: white;
            border: none;
            padding: 12px;
            border-radius: 12px;
            cursor: pointer;
            font-weight: bold;
            transition: transform 0.2s, background 0.3s;
        }

        button#add-btn:hover {
            background-color: #7209b7;
            transform: scale(1.02);
        }

        /* Lista de Rotina */
        ul {
            list-style: none;
            padding: 0;
        }

        .task-item {
            background: white;
            margin-bottom: 10px;
            padding: 15px;
            border-radius: 15px;
            display: flex;
            align-items: center;
            gap: 10px;
            border-left: 5px solid var(--accent-color);
            animation: fadeIn 0.4s ease;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateX(-10px); }
            to { opacity: 1; transform: translateX(0); }
        }

        .task-item input[type="checkbox"] {
            width: 20px;
            height: 20px;
            cursor: pointer;
            accent-color: #7209b7;
        }

        .task-info {
            flex-grow: 1;
        }

        .task-name {
            display: block;
            font-weight: bold;
            color: #555;
            outline: none;
        }

        .task-time {
            font-size: 0.85rem;
            color: #888;
            outline: none;
        }

        .completed .task-name {
            text-decoration: line-through;
            opacity: 0.6;
        }

        .delete-btn {
            background: #ffcfd2;
            color: #d90429;
            border: none;
            padding: 5px 10px;
            border-radius: 8px;
            cursor: pointer;
            font-size: 0.8rem;
        }

        .delete-btn:hover {
            background: #f8adbc;
        }

    </style>
</head>
<body>

    <!-- Elementos flutuantes (Gatinhos, Estrelas, Águas-vivas) -->
    <div class="decor" style="top: 10%; left: 5%;">🐱</div>
    <div class="decor" style="top: 20%; right: 10%; animation-delay: 1s;">✨</div>
    <div class="decor" style="bottom: 15%; left: 10%; animation-delay: 2s;">🪼</div>
    <div class="decor" style="bottom: 10%; right: 5%; animation-delay: 3s;">⭐</div>
    <div class="decor" style="top: 50%; left: 2%; animation-delay: 4s;">🪼</div>
    <div class="decor" style="top: 5%; right: 25%; animation-delay: 1.5s;">🐱</div>
    <div class="decor" style="top: 35%; left: 18%; animation-delay: 2.5s;">🐻</div>
    <div class="decor" style="bottom: 40%; right: 20%; animation-delay: 0.5s;">🎀</div>
    <div class="decor" style="bottom: 5%; left: 45%; animation-delay: 3.5s;">🪭</div>
    <div class="decor" style="top: 80%; left: 5%; animation-delay: 1.2s;"></div>
    <div class="decor" style="top: 15%; left: 45%; animation-delay: 2.8s;">✨</div>
    <div class="decor" style="bottom: 30%; left: 2%; animation-delay: 0.7s;">☁️</div>
    <div class="decor" style="top: 60%; right: 15%; animation-delay: 3.2s;">💖</div>
    <div class="decor" style="top: 25%; left: 60%; animation-delay: 1.5s;">🐱</div>
    <div class="decor" style="bottom: 60%; right: 2%; animation-delay: 2.2s;">🪼</div>
    <div class="decor" style="top: 90%; left: 25%; animation-delay: 4.5s;">⭐</div>
    <div class="decor" style="top: 45%; right: 50%; animation-delay: 1.8s;">🎀</div>
    <div class="decor" style="bottom: 25%; right: 60%; animation-delay: 3.7s;">🐻</div>
    <div class="decor" style="top: 5%; left: 70%; animation-delay: 0.3s;">🪭</div>
    <div class="decor" style="top: 15%; right: 40%; animation-delay: 2.6s;">🪭</div>
    <div class="decor" style="bottom: 75%; left: 85%; animation-delay: 1.1s;">✨</div>
    <div class="decor" style="top: 40%; right: 80%; animation-delay: 3.9s;">🐱</div>
    <div class="decor" style="bottom: 80%; left: 60%; animation-delay: 2.4s;">☁️</div>
    <div class="decor" style="top: 55%; right: 35%; animation-delay: 0.9s;">🪼</div>
    <div class="decor" style="top: 70%; left: 70%; animation-delay: 5s;">🐱</div>
    <div class="decor" style="bottom: 50%; left: 30%; animation-delay: 1s;">✨</div>
    <div class="decor" style="top: 10%; right: 80%; animation-delay: 3s;">🪼</div>
    <div class="decor" style="bottom: 20%; left: 80%; animation-delay: 2s;">🐻</div>
    <div class="decor" style="top: 30%; right: 5%; animation-delay: 4s;">🎀</div>
    <div class="decor" style="bottom: 65%; left: 50%; animation-delay: 0.8s;">🪭</div>
    <div class="decor" style="top: 85%; right: 40%; animation-delay: 1.7s;">🪭</div>
    <div class="decor" style="bottom: 10%; left: 20%; animation-delay: 3.3s;">⭐</div>
    <div class="decor" style="top: 20%; left: 10%; animation-delay: 0.6s;">☁️</div>
    <div class="decor" style="bottom: 45%; right: 70%; animation-delay: 2.9s;">💖</div>

    <div class="container">
        <h1>Minha Rotina 🐱✨</h1>
        
        <div class="input-group">
            <input type="text" id="task-input" placeholder="O que vamos fazer? (Ex: Estudar)">
            <input type="text" id="time-input" placeholder="Horário? (Ex: 14:00)">
            <button id="add-btn">Adicionar à Rotina</button>
        </div>

        <ul id="routine-list">
            <!-- As tarefas aparecerão aqui -->
        </ul>
    </div>

    <script>
        const taskInput = document.getElementById('task-input');
        const timeInput = document.getElementById('time-input');
        const addBtn = document.getElementById('add-btn');
        const routineList = document.getElementById('routine-list');

        // Carregar dados ao iniciar
        let myRoutine = JSON.parse(localStorage.getItem('myRoutine')) || [];

        // Função para verificar se alguma tarefa concluída expirou (24h)
        function checkExpirations() {
            const now = Date.now();
            const twentyFourHours = 24 * 60 * 60 * 1000;
            let changed = false;

            myRoutine.forEach(task => {
                if (task.completed && task.completedAt && (now - task.completedAt >= twentyFourHours)) {
                    task.completed = false;
                    task.completedAt = null;
                    changed = true;
                }
            });

            if (changed) saveAndRender();
        }
        checkExpirations();

        function saveAndRender() {
            localStorage.setItem('myRoutine', JSON.stringify(myRoutine));
            render();
        }

        function addTask() {
            const name = taskInput.value.trim();
            const time = timeInput.value.trim();

            if (name === "") return;

            const newTask = {
                id: Date.now(),
                name: name,
                time: time,
                completed: false,
                completedAt: null
            };

            myRoutine.push(newTask);
            taskInput.value = '';
            timeInput.value = '';
            saveAndRender();
        }
        function deleteTask(id) {
            myRoutine = myRoutine.filter(t => t.id !== id);
            saveAndRender();
        }
        function toggleTask(id) {
            const task = myRoutine.find(t => t.id === id);
            task.completed = !task.completed;
            
            // Registra o horário da conclusão ou limpa se desmarcar
            task.completedAt = task.completed ? Date.now() : null;

            if (task.completed) {
                const meow = new Audio('https://assets.mixkit.co/active_storage/sfx/2568/2568-preview.mp3');
                meow.play();
            }
            saveAndRender();
        }
        // Permite editar o nome clicando diretamente nele
        function updateTaskName(id, newName) {
            const task = myRoutine.find(t => t.id === id);
            task.name = newName;
            localStorage.setItem('myRoutine', JSON.stringify(myRoutine));
        }

        function updateTaskTime(id, newTime) {
            const task = myRoutine.find(t => t.id === id);
            task.time = newTime;
            localStorage.setItem('myRoutine', JSON.stringify(myRoutine));
        }

        function render() {
            routineList.innerHTML = '';

            myRoutine.forEach(task => {
                const li = document.createElement('li');
                li.className = `task-item ${task.completed ? 'completed' : ''}`;
                
                li.innerHTML = `
                    <input type="checkbox" ${task.completed ? 'checked' : ''} onchange="toggleTask(${task.id})">
                    <div class="task-info">
                        <span class="task-name" contenteditable="true" onblur="updateTaskName(${task.id}, this.innerText)">${task.name}</span>
                        <span class="task-time" contenteditable="true" onblur="updateTaskTime(${task.id}, this.innerText)">${task.time || 'Sem horário'}</span>
                    </div>
                    <button class="delete-btn" onclick="deleteTask(${task.id})">Excluir</button>
                `;
                routineList.appendChild(li);
            });
        }

        addBtn.addEventListener('click', addTask);
        
        // Adicionar com a tecla Enter
        taskInput.addEventListener('keypress', (e) => {
            if (e.key === 'Enter') addTask();
        });

        render();
    </script>
</body>
</html>

